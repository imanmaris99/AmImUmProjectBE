# Core app
PORT=8000
APP_DEVELOPMENT=True
HOST_URL=http://127.0.0.1:8000
SECRET_KEY=change-me

# Database
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amimum_db
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amimum_db

# Optional firebase json path (currently unused by app)
JSON_CONFIG=

# Firebase
FIREBASE_SERVICE_ACCOUNT_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Email Delivery
# Use Brevo API in this project (recommended)
EMAIL_PROVIDER=brevo_api
BREVO_API_KEY=
FROM_EMAIL=
SMTP_TIMEOUT_SECONDS=15

# Optional SMTP fallback (only if EMAIL_PROVIDER=smtp)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# RajaOngkir / Komerce Shipping Cost
RAJAONGKIR_API_KEY=
RAJAONGKIR_API_HOST=rajaongkir.komerce.id
RAJAONGKIR_API_BASE_PATH=/api/v1

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
